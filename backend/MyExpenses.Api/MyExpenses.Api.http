@MyExpenses.Api_HostAddress = http://localhost:5000
@token = <your-jwt-token-here>

### ========================================
###  Auth Endpoints
### ========================================

### GET /api/auth/status - 檢查認證狀態
GET {{MyExpenses.Api_HostAddress}}/api/auth/status
Accept: application/json

### POST /api/auth/register - 註冊首個使用者
POST {{MyExpenses.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123",
  "displayName": "Test User"
}

### POST /api/auth/login - 登入
POST {{MyExpenses.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123"
}

### POST /api/auth/2fa/login - 雙因子驗證登入（需先取得 tempToken）
POST {{MyExpenses.Api_HostAddress}}/api/auth/2fa/login
Content-Type: application/json

{
  "tempToken": "<temp-token>",
  "code": "123456"
}

### POST /api/auth/2fa/recovery-login - 使用備用碼登入
POST {{MyExpenses.Api_HostAddress}}/api/auth/2fa/recovery-login
Content-Type: application/json

{
  "tempToken": "<temp-token>",
  "recoveryCode": "ABCD-EFGH-IJKL"
}

### PUT /api/auth/profile - 更新顯示名稱（需登入）
PUT {{MyExpenses.Api_HostAddress}}/api/auth/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "displayName": "New Display Name"
}

### PUT /api/auth/password - 變更密碼（需登入）
PUT {{MyExpenses.Api_HostAddress}}/api/auth/password
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "currentPassword": "password123",
  "newPassword": "newpassword456"
}

### POST /api/auth/logout-all - 所有裝置登出（需登入）
POST {{MyExpenses.Api_HostAddress}}/api/auth/logout-all
Authorization: Bearer {{token}}

### POST /api/auth/2fa/setup - 設定 TOTP 雙因子驗證（需登入）
POST {{MyExpenses.Api_HostAddress}}/api/auth/2fa/setup
Authorization: Bearer {{token}}

### POST /api/auth/2fa/verify - 驗證 2FA 設定（需登入）
POST {{MyExpenses.Api_HostAddress}}/api/auth/2fa/verify
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "123456"
}

### POST /api/auth/2fa/disable - 停用雙因子驗證（需登入）
POST {{MyExpenses.Api_HostAddress}}/api/auth/2fa/disable
Authorization: Bearer {{token}}

### GET /api/auth/2fa/recovery-codes - 重新產生備用碼（需登入）
GET {{MyExpenses.Api_HostAddress}}/api/auth/2fa/recovery-codes
Authorization: Bearer {{token}}

### POST /api/auth/api-tokens - 建立 API Token（需登入）
POST {{MyExpenses.Api_HostAddress}}/api/auth/api-tokens
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "My API Token",
  "scopes": ["read", "write"]
}

### GET /api/auth/api-tokens - 列出所有 API Token（需登入）
GET {{MyExpenses.Api_HostAddress}}/api/auth/api-tokens
Authorization: Bearer {{token}}

### DELETE /api/auth/api-tokens/{id} - 撤銷 API Token（需登入）
DELETE {{MyExpenses.Api_HostAddress}}/api/auth/api-tokens/1
Authorization: Bearer {{token}}


### ========================================
###  Category Endpoints
### ========================================

### GET /api/categories - 分頁列表
GET {{MyExpenses.Api_HostAddress}}/api/categories?page=1&pageSize=20
Accept: application/json

### GET /api/categories?all=true - 全部列表
GET {{MyExpenses.Api_HostAddress}}/api/categories?all=true
Accept: application/json

### GET /api/categories/{id} - 單筆查詢
GET {{MyExpenses.Api_HostAddress}}/api/categories/1
Accept: application/json

### POST /api/categories - 新增
POST {{MyExpenses.Api_HostAddress}}/api/categories
Content-Type: application/json

{
  "name": "測試分類",
  "type": "Expense",
  "icon": "Tag",
  "color": "#FF5733",
  "sortOrder": 50
}

### PUT /api/categories/{id} - 更新
PUT {{MyExpenses.Api_HostAddress}}/api/categories/1
Content-Type: application/json

{
  "name": "更新分類",
  "type": "Expense",
  "icon": "Tag",
  "color": "#33FF57",
  "sortOrder": 51
}

### DELETE /api/categories/{id} - 刪除
DELETE {{MyExpenses.Api_HostAddress}}/api/categories/1

### POST /api/categories/restore-defaults - 恢復預設分類
POST {{MyExpenses.Api_HostAddress}}/api/categories/restore-defaults
Content-Type: application/json


